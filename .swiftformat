# SwiftFormat configuration for Brygga.
#
# Run `swiftformat .` from the repo root to apply.
# CI runs `swiftformat --lint .` and fails on any diff.

--swiftversion 6.2
--indent tab
--tabwidth 4

# Leave the SPDX header alone. Every .swift file starts with:
#   // SPDX-License-Identifier: BSD-3-Clause
#   // Copyright (c) 2026 Brygga contributors
# Managing it here would require keeping the year in sync on two systems;
# the header is small enough that humans notice if it drifts.
--header ignore

# Test helpers rely on `try!` / `!` for brevity on obviously-invariant inputs
# (e.g. parse a hard-coded protocol line that the test itself controls).
# AGENTS.md explicitly permits force-unwrap in tests; the rule would rewrite
# those into `try XCTUnwrap(...)` with no real safety gain.
--disable noForceUnwrapInTests
